{
  "executable": "iwdescr_new",
  "default_command_components": [
    "-g all -E autocreate -B quiet"
  ],
  "test": [
    {
      "name": "default",
      "preamble": [
         "queries_dir=${LILLYMOL_HOME}/data/queries"
      ],
      "args": [ "-N F:${queries_dir}/charges/queries -H a=F:${queries_dir}/hbonds/acceptor",
                " -H d=${queries_dir}/hbonds/donor.qry -H label",
                " -l -u 0 -b 5 -O complex -O dm #{indir}/in.smi"
              ]
    },

    {
      "name": "filter1eq",
      "preamble": [
         "queries_dir=${LILLYMOL_HOME}/data/queries"
      ],
      "args": [ "-N F:${queries_dir}/charges/queries -H a=F:${queries_dir}/hbonds/acceptor",
                " -H d=${queries_dir}/hbonds/donor.qry -H label",
                " -F w_natoms.eq.3",
                " -l -u 0 -b 5 -O complex -O dm #{indir}/in.smi"
              ]
    },

    {
      "name": "filter1gt",
      "args": [
                " -F w_natoms.gt.3",
                " -O none #{indir}/in.smi"
              ]
    },

    {
      "name": "filter1lt",
      "args": [
                " -F w_natoms.lt.4",
                " -O none #{indir}/in.smi"
              ]
    },
    {
       "name": "filter_inconsistent1",
      "preamble": [
         "queries_dir=${LILLYMOL_HOME}/data/queries"
      ],
      "args": [ "-N F:${queries_dir}/charges/queries -H a=F:${queries_dir}/hbonds/acceptor",
                " -H d=${queries_dir}/hbonds/donor.qry -H label",
                " -F w_natoms.eq.3 -F w_natoms.eq.4",
                " -l -u 0 -b 5 -O complex -O dm #{indir}/in.smi"
              ]
    },

    {
       "name": "filter_inconsistent2",
      "preamble": [
         "queries_dir=${LILLYMOL_HOME}/data/queries"
      ],
      "args": [ "-N F:${queries_dir}/charges/queries -H a=F:${queries_dir}/hbonds/acceptor",
                " -H d=${queries_dir}/hbonds/donor.qry -H label",
                " -F w_natoms.eq.3 -F w_amw.gt.100",
                " -l -u 0 -b 5 -O complex -O dm #{indir}/in.smi"
              ]
    },

    {
       "name": "namexref",
      "args": [ " -B namexref=#{indir}/namexref.textproto -u 0",
                " -O none #{indir}/in.smi"
              ]
    },

    {
       "name": "filter_and_prefix",
      "args": [ " -B prefix=Q -F nrings.gt.0",
                " -O none #{indir}/in.smi"
              ]
    },

    {
       "name": "fingerprint_default",
      "args": [ " -G natoms -G w_nrings",
                " -O none #{indir}/in.smi"
              ]
    },

    {
       "name": "prefix_none",
      "args": [ " -B prefix=none -u 0",
                " -O none #{indir}/in.smi"
              ]
    },

    {
       "name": "write_pipeline",
      "args": [ " -B prefix=none -B wpipe",
                " -O none #{indir}/in.smi"
              ]
    }

  ]
}
